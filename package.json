{
  "name": "terminal-macroses",
  "displayName": "Terminal Macroses",
  "description": "Create and manage your macroses for terminal",
  "version": "0.0.1",
  "publisher": "This_Epik",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThisEpik/vs_code_terminal_macroses"
  },
  "homepage": "https://github.com/ThisEpik/vs_code_terminal_macroses",
  "bugs": {
    "url": "https://github.com/ThisEpik/vs_code_terminal_macroses/issues"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "terminalMacros.createMacro",
        "title": "Create New Macro"
      },
      {
        "command": "terminalMacros.editMacro",
        "title": "Edit Macro"
      },
      {
        "command": "terminalMacros.deleteMacro",
        "title": "Delete Macro"
      },
      {
        "command": "terminalMacros.runMacro",
        "title": "Run Macro"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "terminalMacros",
          "title": "Terminal Macros",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "terminalMacros": [
        {
          "id": "terminalMacros",
          "name": "Macros",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "terminalMacros.editMacro",
          "when": "view == terminalMacros && viewItem == macro"
        },
        {
          "command": "terminalMacros.deleteMacro",
          "when": "view == terminalMacros && viewItem == macro"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
